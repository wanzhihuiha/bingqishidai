{
  "schema_version": 1,
  "items": [
    {
      "id": "refugee_help_early",
      "type": "refugee",
      "title": "难民求援",
      "body": "几名冻僵的求助者停在营门外。他们说身后还有孩子，但营地的食物也不宽裕。",
      "trigger": {
        "min_day": 2,
        "max_day": 8
      },
      "choices": [
        {
          "id": "accept",
          "label": "接纳他们",
          "conditions": {
            "min_resources": {
              "food": 8
            }
          },
          "effects": [
            {
              "effect_type": "resource_delta",
              "target_id": "food",
              "value": -8,
              "note": "接纳求助者需要分出食物。"
            },
            {
              "effect_type": "state_change",
              "target_id": "population.healthy",
              "value": 1,
              "note": "一名幸存者加入营地。"
            },
            {
              "effect_type": "resource_delta",
              "target_id": "hope",
              "value": 3,
              "note": "营地因为救助他人而更有希望。"
            }
          ],
          "result_text": "求助者被带到寒炉旁，营地多了一双能干活的手。"
        },
        {
          "id": "give_food",
          "label": "给少量食物",
          "conditions": {
            "min_resources": {
              "food": 4
            }
          },
          "effects": [
            {
              "effect_type": "resource_delta",
              "target_id": "food",
              "value": -4,
              "note": "分出一小包食物。"
            },
            {
              "effect_type": "resource_delta",
              "target_id": "hope",
              "value": 1,
              "note": "至少没有让他们空手离开。"
            }
          ],
          "result_text": "守卫把食物交给他们，求助者向营地深深鞠了一躬。"
        },
        {
          "id": "refuse",
          "label": "拒绝",
          "effects": [
            {
              "effect_type": "resource_delta",
              "target_id": "hope",
              "value": -2,
              "note": "拒绝救援让营地气氛沉重。"
            },
            {
              "effect_type": "state_change",
              "target_id": "morale_score",
              "value": -2,
              "note": "守卫和幸存者都不好受。"
            }
          ],
          "result_text": "营门关上后，寒风里只剩下脚步远去的声音。"
        }
      ],
      "weight": 8,
      "once_only": false,
      "cooldown_days": 4,
      "unique_key": "refugee_help"
    },
    {
